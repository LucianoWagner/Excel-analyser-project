# ── LLM ──
GROQ_API_KEY=your_groq_api_key_here

# ── Database ──
DATABASE_URL=postgresql+asyncpg://excel_user:excel_pass_2024@localhost:5432/excel_chat

# ── JWT ──
JWT_SECRET=change_this_to_a_random_secret_key_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── Admin default (created on first startup) ──
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=admin123

# ── Limits ──
MAX_FILE_SIZE_MB=10
MAX_ROWS=100000
QUERY_TIMEOUT_SECONDS=30

# ── Sessions ──
SESSION_TTL_MINUTES=60
MAX_SESSIONS=50

# ── Rate Limiting ──
RATE_LIMIT_QUERY=10/minute
RATE_LIMIT_UPLOAD=5/minute
RATE_LIMIT_AUTH=10/minute
